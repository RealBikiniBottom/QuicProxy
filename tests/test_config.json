{
  "inbounds": {
    "mix_test": {
      "type": "mix",
      "address": "127.0.0.1",
      "port": 0
    }
  },
  "dns": {
    "default_server": "local_dns",
    "servers": {
      "local_dns": {
        "type": "udp",
        "address": "8.8.8.8",
        "port": 53,
        "outbound": "direct_out"
